# next-auth@4 déclare un peerOptional nodemailer@^7, mais ACRA utilise nodemailer@^9
# directement (SMTP) et n'utilise PAS le provider Email de next-auth. Ce peer optionnel
# est donc sans objet : on tolère le mismatch pour que `npm ci` passe (CI, Docker, local).
legacy-peer-deps=true

# Increase network timeouts for Docker builds with slow/intermittent connectivity
fetch-timeout=600000
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-retries=5
