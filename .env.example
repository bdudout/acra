# =============================================================================
# ACRA — Exemple de configuration (.env.example)
# =============================================================================
#
# Ce fichier est un MODÈLE. Ne le modifiez pas directement.
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  DÉMARRAGE RAPIDE                                                       │
# │                                                                         │
# │  Exécutez le script de setup pour créer votre .env automatiquement :   │
# │                                                                         │
# │      ./scripts/setup.sh                                                 │
# │  ou  make setup                                                         │
# │                                                                         │
# │  Le script génère des secrets aléatoires et vous guide pas à pas.      │
# └─────────────────────────────────────────────────────────────────────────┘
#
# Si vous préférez configurer manuellement :
#     cp .env.example .env
# puis remplacez TOUTES les valeurs <À MODIFIER>.
#
# =============================================================================


# ── Base de données PostgreSQL ────────────────────────────────────────────────
#
# Ces trois variables configurent le serveur PostgreSQL lancé par Docker Compose.
#
# POSTGRES_USER : nom d'utilisateur PostgreSQL (non-générique recommandé)
POSTGRES_USER=acra_user

# POSTGRES_PASSWORD : mot de passe PostgreSQL
#   CRITIQUE : doit être aléatoire et unique.
#   Générer : openssl rand -base64 24 | tr -d '/+=' | head -c 32
#   Exemple : K8mXp2vQ9rNs4wYjA7cL3tZeF6bH1dWu
POSTGRES_PASSWORD=CHANGEZ_MOI_openssl_rand_base64_24

# POSTGRES_DB : nom de la base de données
POSTGRES_DB=acra_rm


# ── URL de connexion Prisma ───────────────────────────────────────────────────
#
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
#   Docker Compose : HOST = "db" (nom du service)
#   Local sans Docker : HOST = "localhost"
#   Production distante : HOST = adresse du serveur PostgreSQL
#
# Exemples :
#   Docker : postgresql://acra_user:monpassword@db:5432/acra_rm
#   Local  : postgresql://acra_user:monpassword@localhost:5432/acra_rm
#
DATABASE_URL=postgresql://acra_user:CHANGEZ_MOI@db:5432/acra_rm


# ── Authentification NextAuth.js ──────────────────────────────────────────────
#
# NEXTAUTH_SECRET : secret pour signer les tokens JWT de session.
#
#   CRITIQUE : doit être aléatoire, long (>= 32 chars), unique par env.
#   Si compromis : tous les tokens existants sont invalidés.
#
#   Générer : openssl rand -base64 48
#   Exemple  : K8mXp2vQ9rNs4wYjA7cL3tZeF6bH1dWuR5nBqPkCsYgMhT0iEaOxJvDl2fU
#
NEXTAUTH_SECRET=CHANGEZ_MOI_openssl_rand_base64_48

# CRON_SECRET (optionnel) : jeton protégeant les endpoints planifiés (/api/cron/*),
# notamment les snapshots de conformité périodiques (mode AUTO). Appelez l'endpoint
# depuis un planificateur externe avec l'en-tête « Authorization: Bearer <CRON_SECRET> ».
# Ex. cron quotidien : curl -X POST -H "Authorization: Bearer $CRON_SECRET" \
#     https://<host>/api/cron/conformite-snapshots
# Si absent, les endpoints cron répondent 503 (désactivés).
# CRON_SECRET=CHANGEZ_MOI_openssl_rand_base64_32

# NEXTAUTH_URL : URL publique de l'application.
#
#   Développement : http://localhost:3000
#   Production    : https://votre-domaine.com  (HTTPS obligatoire)
#   Reverse proxy : mettez l'URL externe (ex: https://acra.monentreprise.fr)
#
NEXTAUTH_URL=http://localhost:3000


# ── Chiffrement des secrets au repos (recommandé) ────────────────────────────
#
# SECRETS_ENCRYPTION_KEY : clé servant à chiffrer en base (AES-256-GCM) les secrets
#   sensibles configurés via l'admin (Client Secret OIDC, clés/secret SMS).
#
#   Si absente, l'application retombe sur NEXTAUTH_SECRET. Pour une rotation
#   indépendante des secrets de session, définir une clé dédiée ici.
#   CRITIQUE : si cette clé change, les secrets déjà chiffrés deviennent
#   indéchiffrables et devront être ressaisis dans l'interface d'administration.
#
#   Générer : openssl rand -base64 48
#
SECRETS_ENCRYPTION_KEY=
